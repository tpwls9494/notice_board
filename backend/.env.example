DATABASE_URL=postgresql://postgres:password@postgres:5432/company_board
REDIS_URL=redis://redis:6379/0

SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
REQUEST_LOG_ENABLED=true
SLOW_REQUEST_THRESHOLD_MS=500
API_DOCS_ENABLED=true

# OAuth (optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
OAUTH_FRONTEND_DEFAULT_REDIRECT=http://localhost:5173/oauth/callback
EMAIL_VERIFICATION_FRONTEND_BASE_URL=http://localhost:5173
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
EMAIL_VERIFICATION_RESEND_WINDOW_SECONDS=600
EMAIL_VERIFICATION_RESEND_MAX_ATTEMPTS=5
SIGNUP_EMAIL_CODE_TTL_MINUTES=10
SIGNUP_EMAIL_CODE_LENGTH=6
SIGNUP_EMAIL_SEND_WINDOW_SECONDS=600
SIGNUP_EMAIL_SEND_MAX_ATTEMPTS=5
SIGNUP_EMAIL_CONFIRM_WINDOW_SECONDS=600
SIGNUP_EMAIL_CONFIRM_MAX_ATTEMPTS=10
SIGNUP_EMAIL_VERIFICATION_TICKET_TTL_MINUTES=30

# SMTP (optional for email verification delivery)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=jion
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# AI assistant
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_ROUTE_MODEL=gpt-4.1-mini
AI_CHAT_MODEL=gpt-4.1-mini
AI_EDITOR_MODEL=gpt-4.1-mini
AI_EDITOR_FALLBACK_MODEL=gpt-4.1-mini
AI_TIMEOUT_SECONDS=12
AI_EDITOR_TIMEOUT_SECONDS=45
AI_ROUTE_MAX_TOKENS=120
AI_CHAT_MAX_TOKENS=600
AI_EDITOR_MAX_TOKENS=900
AI_RATE_LIMIT_WINDOW_SECONDS=60
AI_RATE_LIMIT_MAX_REQUESTS=20
AI_CACHE_TTL_SECONDS=180
AI_CACHE_MAX_ITEMS=500
AI_INPUT_COST_PER_1K_USD=0
AI_OUTPUT_COST_PER_1K_USD=0

POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=company_board
